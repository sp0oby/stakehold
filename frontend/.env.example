# ─── Public vars (shipped to the browser) ─────────────────────────────────
# OPTIONAL for local dev only — leave unset in production so the browser
# talks to our server-side `/api/rpc` proxy instead of hitting the provider
# directly. Setting this in prod would re-expose the upstream key in DevTools.
# NEXT_PUBLIC_SEPOLIA_RPC_URL=
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
# Optional. Only set this once you own a real domain — e.g. https://stakehold.xyz.
# If unset, the app auto-resolves to Vercel's production URL in production,
# the per-deploy preview URL in preview builds, or http://localhost:3000 in dev.
# Used exclusively to build absolute OG / Twitter-card image URLs.
# NEXT_PUBLIC_SITE_URL=

# Stakehold stack — fill in after running `forge script DeployFactory`
NEXT_PUBLIC_FACTORY_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_LENS_ADDRESS=0x0000000000000000000000000000000000000000

# Optional: pin a specific property to the homepage as "featured".
# If unset, the most recent property launched is featured.
NEXT_PUBLIC_FEATURED_PROPERTY=

# Optional: override the public IPFS gateway used for reads (content links,
# media previews, legal docs). Defaults to https://ipfs.filebase.io/ipfs/.
# Any IPFS gateway works — dweb.link, w3s.link, a self-hosted one, etc.
NEXT_PUBLIC_IPFS_GATEWAY=https://ipfs.filebase.io/ipfs/

# ─── Server-only — NEVER prefix with NEXT_PUBLIC_ ─────────────────────────
# JSON-RPC upstreams for the /api/rpc proxy, tried in order.
#
# ALL OF THESE ARE OPTIONAL. With nothing set, the proxy falls back to a
# built-in chain of public Sepolia RPCs (PublicNode, dRPC, Ankr,
# sepolia.org) that don't require keys or rate-limit normal app traffic.
#
# SEPOLIA_RPC_URLS   — comma-separated list, fully overrides the defaults.
#                      Use this if you want a specific provider order.
# SEPOLIA_RPC_URL    — single URL (e.g. an Alchemy key). When set, it's
#                      tried FIRST and the public defaults are appended
#                      as fallbacks, so a bad key never takes the app down.
#
# SEPOLIA_RPC_URLS=https://sepolia.drpc.org,https://ethereum-sepolia-rpc.publicnode.com
# SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# Filebase IPFS access token. Generate one in the Filebase dashboard under
# "Access Keys" → "IPFS". It's scoped to a single IPFS bucket on your account.
# Free plan gives 5 GB of storage and plenty of pins for a demo.
FILEBASE_IPFS_TOKEN=

# Optional: override the gateway URL used by the upload route when echoing
# back the pinned file link to the client. Defaults to the public one above.
# IPFS_GATEWAY=https://ipfs.filebase.io/ipfs/
