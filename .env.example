# ─────────────────────────────────────────────────────────────
# Foundry / contract deployment (contracts/.env)
# ─────────────────────────────────────────────────────────────
# RPC for Sepolia (Alchemy / Infura / QuickNode)
SEPOLIA_RPC_URL=

# Deployer private key (DO NOT COMMIT — bots scrape GitHub for leaked keys)
PRIVATE_KEY=

# Etherscan API key for contract verification
ETHERSCAN_API_KEY=

# ─────────────────────────────────────────────────────────────
# Frontend — Next.js public vars (frontend/.env.local)
# ─────────────────────────────────────────────────────────────
# OPTIONAL for local dev only — leave unset in production. When unset, the
# browser goes through our `/api/rpc` server proxy so the provider key stays
# secret. Setting this in prod re-exposes the key in DevTools.
# NEXT_PUBLIC_SEPOLIA_RPC_URL=

# Deployed Factory + Lens addresses on Sepolia (filled in after deploy)
NEXT_PUBLIC_FACTORY_ADDRESS=
NEXT_PUBLIC_LENS_ADDRESS=

# Optional: pin a specific property to the homepage as "featured"
NEXT_PUBLIC_FEATURED_PROPERTY=

# WalletConnect Cloud project id (https://cloud.walletconnect.com/)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Optional: override the public IPFS gateway (defaults to Filebase's)
NEXT_PUBLIC_IPFS_GATEWAY=https://ipfs.filebase.io/ipfs/

# ─────────────────────────────────────────────────────────────
# Frontend — server-only secrets (frontend/.env.local, never NEXT_PUBLIC_)
# ─────────────────────────────────────────────────────────────
# The /api/rpc proxy defaults to a built-in chain of public Sepolia RPCs
# (PublicNode, dRPC, Ankr, sepolia.org) — no keys, no rate limits for
# normal app traffic. Only set these if you want to override the defaults:
#
# SEPOLIA_RPC_URLS  — comma-separated list, tried in order.
# SEPOLIA_RPC_URL   — single URL, tried first; public defaults appended.
#
# SEPOLIA_RPC_URLS=
# SEPOLIA_RPC_URL=

# Filebase IPFS access token — stays on the server, never shipped to browser.
# Generate in Filebase dashboard → "Access Keys" → "IPFS access key" (scoped
# to your IPFS bucket). Free tier gives 5 GB of storage.
FILEBASE_IPFS_TOKEN=
